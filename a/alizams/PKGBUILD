# Maintainer: Fabio 'Lolix' Loli <fabio.loli@disroot.org> -> https://github.com/FabioLolix

pkgname=alizams
pkgver=1.9.12
pkgrel=1
pkgdesc="Qt6 DICOM Viewer"
arch=(x86_64 i686 arm armv6h armv7h aarch64)
url="https://www.aliza-dicom-viewer.com/"
license=(GPL-3.0-only)
depends=(
    glibc
    hicolor-icon-theme
    itk
    libgcc
    libstdc++
    qt6-5compat
    qt6-base
    )
makedepends=(
    cmake
    eigen
    git
    qt6-svg
    )
source=("git+https://github.com/AlizaMedicalImaging/AlizaMS.git#tag=v${pkgver}")
sha256sums=('fe53dbc67c8c229ea88d84948b5aeb273c93bcf680d2345eec70cb90e2313bdb')

build() {
  local _flags=(
    -DALIZA_QT_VERSION:STRING=6
  )

  cmake -B build -S "AlizaMS" -Wno-dev \
    -DCMAKE_BUILD_TYPE=None \
    -DCMAKE_INSTALL_PREFIX=/usr \
    "${_flags[@]}"

  cmake --build build
}

package() {
  DESTDIR="${pkgdir}" cmake --install build
}
